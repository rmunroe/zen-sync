init_storagebox() {
    local local_profile="$1"

    local age_bin
    age_bin=$(resolve_tool_path "age") || die "age not installed in this shell. Install age and ensure bash can find it."
    local age_keygen_bin
    age_keygen_bin=$(resolve_age_keygen "$age_bin") || die "age-keygen not found. Install full age package (includes age-keygen)."

    prompt "Storage Box WebDAV URL (e.g. https://u12345.your-storagebox.de)"; read -r storage_url
    if [[ "$storage_url" != http://* && "$storage_url" != https://* ]]; then
