    storage_pass=$(secret_prompt "Storage Box password")
    prompt "Remote folder path" "zen-sync"; read -r storage_path
    storage_path="${storage_path:-zen-sync}"

    printf "\n"
    step "  ⟳" "Testing Storage Box connection..."
    local storage_py
    storage_py=$(find_py "storagebox.py")
    local test_config
    test_config=$(printf '{"url":"%s","username":"%s","password":"%s","path":"%s"}' \
        "$storage_url" "$storage_user" "$storage_pass" "$storage_path")
    local test_output
    if test_output=$("$PYTHON_BIN" "$storage_py" test "$test_config" 2>&1); then
        ok "Storage Box connected"
    else
        if [[ -n "$test_output" ]]; then
            dim "  backend error:"
            while IFS= read -r line; do
                [[ -n "$line" ]] && dim "  $line"
            done <<< "$test_output"
        fi
        die "could not connect to Storage Box. Check URL, username, password, and path."
    fi

    printf "\n"
    printf "  ${WHITE}Encryption method:${R}\n\n"
    printf "    ${PURPLE}❯${R} ${GREEN}1${R}  ${B}Passphrase${R}   ${D}Same passphrase on all devices (recommended)${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}2${R}  ${B}Key file${R}     ${D}Generate key, copy to other devices${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}3${R}  ${B}Import key${R}   ${D}Use an existing age key file${R}\n"
