# ─── Push ─────────────────────────────────────────────────────────────
cmd_push() {
    load_config
    local restart=false
    for arg in "$@"; do
        [[ "$arg" == "--restart" ]] && restart=true
    done

    if [[ "$MODE" == "ssh" ]]; then
        push_ssh "$restart"
    else
        push_remote "$restart"
    fi
}

push_ssh() {
    local restart=$1
    local remote="$REMOTE_USER@$REMOTE_HOST"

    header "push"
    printf "  ${D}local${R} ${PURPLE}→${R} ${WHITE}${B}%s${R}\n\n" "$REMOTE_HOST"

    [[ "$restart" == "true" ]] && zen_close_remote "$remote"

    for f in "${SYNC_FILES[@]}"; do
        local src="$LOCAL_PROFILE/$f"
        if [[ -f "$src" ]]; then
            if scp -q "$src" "$remote:$REMOTE_PROFILE/$f" 2>/dev/null; then
                ok "$f"
            else
                fail "$f"
            fi
        fi
    done

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_remote "$remote"

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

push_remote() {
    local restart=$1

    local backend_py config_json target_label
    if [[ "$MODE" == "r2" ]]; then
        backend_py=$(find_py "cloud.py")
        config_json=$(cloud_config_json)
        target_label="R2 cloud"
    else
        backend_py=$(find_py "storagebox.py")
        config_json=$(storagebox_config_json)
        target_label="Storage Box"
    fi

    header "push"
    printf "  ${D}local${R} ${PURPLE}→${R} ${WHITE}${B}%s${R}\n\n" "$target_label"

    step "  ↑" "Encrypting and uploading..."
    local result
    result=$("$PYTHON_BIN" "$backend_py" push "$config_json") || die "upload failed"

    local raw_size enc_size
    raw_size=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['raw_size'])")
    enc_size=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['encrypted_size'])")

    ok "Uploaded $(human_bytes "$raw_size") (encrypted: $(human_bytes "$enc_size"))"

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

# ─── Pull ─────────────────────────────────────────────────────────────
# ─── Preserve per-machine extension identity across prefs.js sync ─────
# prefs.js carries "extensions.webextensions.uuids": a map of extension id to a
# random moz-extension:// UUID that Zen assigns when the extension is installed
# on THIS machine. That UUID is the key to the extension's local storage. When a
# pull overwrites prefs.js with another machine's copy, the map is replaced and
# every extension is detached from its data — which leaves request-blocking
# extensions (uBlock Origin, DuckDuckGo, etc.) in a broken state where they
# cancel every request and the browser can no longer open any URL.
#
# Fix: capture this machine's map before the pull, then splice it back into the
# imported prefs.js so extensions stay bound to their own local storage.
EXT_UUIDS_KEY='^user_pref("extensions.webextensions.uuids"'

capture_local_extension_uuids() {
    ZEN_SYNC_LOCAL_EXT_UUIDS=""
    [[ -f "$LOCAL_PROFILE/prefs.js" ]] || return 0
    ZEN_SYNC_LOCAL_EXT_UUIDS=$(grep -m1 "$EXT_UUIDS_KEY" "$LOCAL_PROFILE/prefs.js" 2>/dev/null || true)
}

restore_local_extension_uuids() {
    local prefs="$LOCAL_PROFILE/prefs.js"
    [[ -f "$prefs" ]] || return 0
    local bak="$prefs.zen-sync-uuids.bak"
    cp "$prefs" "$bak" || return 0
    # Rewrite prefs.js in place (preserves file permissions): drop the imported
    # map, then re-append this machine's own map if it had one.
    {
        grep -v "$EXT_UUIDS_KEY" "$bak" 2>/dev/null || true
        if [[ -n "${ZEN_SYNC_LOCAL_EXT_UUIDS:-}" ]]; then
            printf '%s\n' "$ZEN_SYNC_LOCAL_EXT_UUIDS"
        fi
    } > "$prefs"
    rm -f "$bak"
}

cmd_pull() {
    load_config
    local restart=false
    local spaces_only=false
    for arg in "$@"; do
        [[ "$arg" == "--restart" ]] && restart=true
        [[ "$arg" == "--spaces-only" ]] && spaces_only=true
    done

    # Remember this machine's extension UUID map before prefs.js is overwritten.
    [[ "$spaces_only" == "true" ]] || capture_local_extension_uuids

    if [[ "$MODE" == "ssh" ]]; then
        pull_ssh "$restart" "$spaces_only"
    else
        pull_remote "$restart" "$spaces_only"
    fi
}

pull_ssh() {
    local restart=$1
    local spaces_only=$2
    local remote="$REMOTE_USER@$REMOTE_HOST"

    header "pull"
    printf "  ${WHITE}${B}%s${R} ${PURPLE}←${R} ${D}local${R}\n\n" "$REMOTE_HOST"

    [[ "$restart" == "true" ]] && zen_close_local

    local files=("${SYNC_FILES[@]}")
    if [[ "$spaces_only" == "true" ]]; then
        files=("${SPACES_ONLY_FILES[@]}")
        dim "  Spaces-only mode: skipping sessionstore, prefs, and containers"
    fi

    for f in "${files[@]}"; do
        local dst="$LOCAL_PROFILE/$f"
        mkdir -p "$(dirname "$dst")"
        if scp -q "$remote:$REMOTE_PROFILE/$f" "$dst" 2>/dev/null; then
            ok "$f"
        else
            fail "$f (not found)"
        fi
    done

    # Keep this machine's extension UUID map (prefs.js was just overwritten).
    [[ "$spaces_only" == "true" ]] || restore_local_extension_uuids

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_local

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

pull_remote() {
    local restart=$1
    local spaces_only=$2

    local backend_py config_json source_label
    if [[ "$MODE" == "r2" ]]; then
        backend_py=$(find_py "cloud.py")
        config_json=$(cloud_config_json)
        source_label="R2 cloud"
    else
        backend_py=$(find_py "storagebox.py")
        config_json=$(storagebox_config_json)
        source_label="Storage Box"
    fi

    header "pull"
    printf "  ${WHITE}${B}%s${R} ${PURPLE}←${R} ${D}local${R}\n\n" "$source_label"

    [[ "$restart" == "true" ]] && zen_close_local

    if [[ "$spaces_only" == "true" ]]; then
        step "  ↓" "Downloading and decrypting (spaces-only)..."
        dim "  Spaces-only mode: skipping sessionstore, prefs, and containers"

        local tmp_dir
        tmp_dir=$(mktemp -d)
        local pull_config
        pull_config=$(echo "$config_json" | "$PYTHON_BIN" -c "import sys,json; d=json.load(sys.stdin); d['profile']='$tmp_dir'; print(json.dumps(d))")

        local result
        if ! result=$("$PYTHON_BIN" "$backend_py" pull "$pull_config"); then
            rm -rf "$tmp_dir"
            die "download failed"
        fi

        local error
        error=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',''))" 2>/dev/null)
        if [[ -n "$error" ]]; then
            rm -rf "$tmp_dir"
            die "$error"
        fi

        for f in "${SPACES_ONLY_FILES[@]}"; do
            local src="$tmp_dir/$f"
            local dst="$LOCAL_PROFILE/$f"
            mkdir -p "$(dirname "$dst")"
            if [[ -f "$src" ]]; then
                cp "$src" "$dst" || { rm -rf "$tmp_dir"; die "failed to import $f"; }
                ok "$f"
            else
                fail "$f (not found)"
            fi
        done
        rm -rf "$tmp_dir"
    else
        step "  ↓" "Downloading and decrypting..."
        local result
        result=$("$PYTHON_BIN" "$backend_py" pull "$config_json") || die "download failed"

        local error
        error=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',''))" 2>/dev/null)
        if [[ -n "$error" ]]; then
            die "$error"
        fi

        local size
        size=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['size'])")
        ok "Downloaded $(human_bytes "$size")"
    fi

    # Keep this machine's extension UUID map (prefs.js was just overwritten).
    [[ "$spaces_only" == "true" ]] || restore_local_extension_uuids

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_local

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

backup_remote_ssh() {
    local keep="$1"
    local remote="$REMOTE_USER@$REMOTE_HOST"

    step "  ⟳" "Creating remote backup on SSH source..."
    local result
    result=$(ssh "$remote" "sh -s" -- "$REMOTE_PROFILE" "$keep" <<'EOF'
set -e
profile="$1"
keep="$2"
backup_root="$profile/zen-sync-backups"
mkdir -p "$backup_root"

slot="$keep"
while [ "$slot" -ge 1 ]; do
    if [ "$slot" -eq "$keep" ]; then
        rm -rf "$backup_root/$slot"
    fi
    if [ "$slot" -gt 1 ] && [ -d "$backup_root/$((slot-1))" ]; then
        mv "$backup_root/$((slot-1))" "$backup_root/$slot"
    fi
    slot=$((slot-1))
done

mkdir -p "$backup_root/1"
copied=0
for f in \
    "zen-sessions.jsonlz4" \
    "zen-sessions-backup/clean.jsonlz4" \
    "sessionstore-backups/recovery.jsonlz4" \
    "sessionstore-backups/recovery.baklz4" \
    "sessionstore-backups/previous.jsonlz4" \
    "prefs.js" \
    "containers.json"; do
    src="$profile/$f"
    dst="$backup_root/1/$f"
    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
        copied=1
    fi
done

if [ "$copied" -eq 1 ]; then
    echo "created"
else
    rm -rf "$backup_root/1"
    echo "empty"
fi
EOF
) || die "could not create SSH remote backup"

if [[ "$result" == *"created"* ]]; then
    ok "Remote backup created (kept: $keep)"
else
    dim "  No remote session found to back up"
fi
}

backup_remote_object_store() {
    local keep="$1"
    local backend_py config_json label

    if [[ "$MODE" == "r2" ]]; then
        backend_py=$(find_py "cloud.py")
        config_json=$(cloud_config_json)
        label="R2 cloud"
    else
        backend_py=$(find_py "storagebox.py")
        config_json=$(storagebox_config_json)
        label="Storage Box"
    fi

    step "  ⟳" "Creating remote backup on $label..."

    local backup_config
    backup_config=$(echo "$config_json" | "$PYTHON_BIN" -c "import json,sys; d=json.load(sys.stdin); d['backup_keep']=$keep; print(json.dumps(d))")

    local result
    if ! result=$("$PYTHON_BIN" "$backend_py" backup "$backup_config" 2>&1); then
        [[ -n "$result" ]] && dim "  $result"
        die "could not create remote backup"
    fi

    local created
    created=$(echo "$result" | "$PYTHON_BIN" -c "import json,sys; d=json.load(sys.stdin); print('true' if d.get('created') else 'false')" 2>/dev/null || echo "false")

    if [[ "$created" == "true" ]]; then
        ok "Remote backup created (kept: $keep)"
    else
        dim "  No remote session found to back up"
    fi
}

backup_remote_source() {
    local keep="$1"

    if [[ "$MODE" == "ssh" ]]; then
        backup_remote_ssh "$keep"
    else
        backup_remote_object_store "$keep"
    fi
}

cmd_sync() {
    load_config

    local keep=3
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --keep)
                shift
                [[ $# -gt 0 ]] || die "missing value for --keep"
                keep="$1"
                ;;
            --keep=*)
                keep="${1#*=}"
                ;;
            *)
                die "unknown option for sync: $1"
                ;;
        esac
        shift
    done

    [[ "$keep" =~ ^[0-9]+$ ]] || die "--keep must be a positive integer"
    (( keep >= 1 )) || die "--keep must be at least 1"

    header "sync"
    dim "  Flow: backup remote source → merge latest into local → push merged result"
    printf "\n"

    backup_remote_source "$keep"
    printf "\n"

    cmd_merge
    cmd_push
}

# ─── Status ───────────────────────────────────────────────────────────
read_spaces() {
    "$PYTHON_BIN" -c "
import ctypes, ctypes.util, json, platform, struct, sys

def load_lz4():
    names = []
    system = platform.system().lower()
    if system == 'linux':
        names.extend(['liblz4.so.1', 'liblz4.so'])
    elif system == 'darwin':
        names.extend(['liblz4.1.dylib', 'liblz4.dylib'])
    elif system == 'windows':
        names.extend(['liblz4.dll', 'lz4.dll'])
    found = ctypes.util.find_library('lz4')
    if found:
        names.append(found)
    for name in names:
        try:
            return ctypes.CDLL(name)
        except OSError:
            pass
    raise RuntimeError('Unable to load liblz4')

lib = load_lz4()
with open(sys.argv[1], 'rb') as f:
    data = f.read()
size = struct.unpack('<I', data[8:12])[0]
dst = ctypes.create_string_buffer(size)
lib.LZ4_decompress_safe(data[12:], dst, len(data)-12, size)
j = json.loads(dst.raw[:size])
print(f'{len(j[\"spaces\"])} spaces, {len(j[\"tabs\"])} tabs')
for s in sorted(j['spaces'], key=lambda x: x.get('position', 99999)):
    icon = s.get('icon', ' ')
    print(f'  {icon}  {s[\"name\"]}')
" "$1"
}

cmd_status() {
    load_config

    header "status"

    printf "  ${PURPLE}${B}LOCAL${R}\n"
    printf "  ${D}%s${R}\n" "$LOCAL_PROFILE"
    read_spaces "$LOCAL_PROFILE/zen-sessions.jsonlz4"

    printf "\n"

    if [[ "$MODE" == "ssh" ]]; then
        local remote="$REMOTE_USER@$REMOTE_HOST"
        printf "  ${PURPLE}${B}REMOTE${R} ${D}(%s)${R}\n" "$REMOTE_HOST"
        printf "  ${D}%s${R}\n" "$REMOTE_PROFILE"
        local tmp=$(mktemp)
        scp -q "$remote:$REMOTE_PROFILE/zen-sessions.jsonlz4" "$tmp" 2>/dev/null \
            && read_spaces "$tmp" \
            || fail "could not read remote sessions"
        rm -f "$tmp"
    else
        local backend_py config_json label
        if [[ "$MODE" == "r2" ]]; then
            backend_py=$(find_py "cloud.py")
            config_json=$(cloud_config_json)
            label="R2 cloud"
        else
            backend_py=$(find_py "storagebox.py")
            config_json=$(storagebox_config_json)
            label="Storage Box"
        fi
        printf "  ${PURPLE}${B}REMOTE${R} ${D}(%s)${R}\n" "$label"
        local result
        result=$("$PYTHON_BIN" "$backend_py" status "$config_json" 2>/dev/null) || { fail "could not read remote"; printf "\n"; return; }

        local error
        error=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',''))" 2>/dev/null)
        if [[ -n "$error" ]]; then
            fail "$error"
        else
            local ts hostname
            ts=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['timestamp'])")
            hostname=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['hostname'])")
            dim "  Last push: $ts from $hostname"

            # Download and read spaces
            local tmp_dir=$(mktemp -d)
            "$PYTHON_BIN" "$backend_py" pull "$(echo "$config_json" | "$PYTHON_BIN" -c "import sys,json; d=json.load(sys.stdin); d['profile']='$tmp_dir'; print(json.dumps(d))")" >/dev/null 2>&1
            [[ -f "$tmp_dir/zen-sessions.jsonlz4" ]] && read_spaces "$tmp_dir/zen-sessions.jsonlz4"
            rm -rf "$tmp_dir"
        fi
    fi

    printf "\n"
}

cmd_extract_key() {
    load_config

    [[ "$#" -le 1 ]] || die "usage: zen-sync extract-key [output-file]"
    [[ "$MODE" == "r2" || "$MODE" == "storagebox" ]] || die "extract-key is only available in r2 or storagebox mode"
    [[ "${AGE_MODE:-keyfile}" == "keyfile" ]] || die "current config uses passphrase mode, no key file to extract"

    local source_key
    source_key="${AGE_KEY_PATH/#\~/$HOME}"
    [[ -n "$source_key" ]] || die "AGE_KEY_PATH is missing in config"
    [[ -f "$source_key" ]] || die "age key file not found: $source_key"

    local output_path
    output_path="${1:-$PWD/zen-sync-age-key-$(date +%Y%m%d-%H%M%S).txt}"
    output_path="${output_path/#\~/$HOME}"

    header "extract-key"

    if [[ "$source_key" == "$output_path" ]]; then
        chmod 600 "$output_path" 2>/dev/null || true
        ok "Key already at $output_path"
        printf "\n"
        return 0
    fi

    [[ ! -e "$output_path" ]] || die "output file already exists: $output_path"

    mkdir -p "$(dirname "$output_path")"
    cp "$source_key" "$output_path" || die "failed to export key to $output_path"
    chmod 600 "$output_path"

    ok "Key extracted to $output_path"
    dim "  Keep this file private. Anyone with it can decrypt your synced archive."
    printf "\n"
}

set_config_local_profile() {
    local new_profile="$1"
    local tmp
    tmp=$(mktemp)

    awk -v profile="$new_profile" '
        BEGIN { q=sprintf("%c",34); replaced=0 }
        /^LOCAL_PROFILE=/ {
            print "LOCAL_PROFILE=" q profile q
            replaced=1
            next
        }
        { print }
        END {
            if (replaced == 0) {
                print "LOCAL_PROFILE=" q profile q
            }
        }
    ' "$CONFIG_FILE" > "$tmp"

    mv "$tmp" "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
}

cmd_set_local_profile() {
    [[ "$#" -le 1 ]] || die "usage: zen-sync set-local-profile [profile-path]"
    [[ -f "$CONFIG_FILE" ]] || die "not configured. Run 'zen-sync init' first."

    local new_profile
    if [[ "$#" -eq 1 ]]; then
        new_profile="$1"
        new_profile="${new_profile/#\~/$HOME}"
    else
        step "  ⟳" "Finding local profile..."
        new_profile=$(find_local_profile)
    fi

    [[ -d "$new_profile" ]] || die "profile path not found: $new_profile"
    [[ -f "$new_profile/zen-sessions.jsonlz4" ]] || die "invalid profile: missing zen-sessions.jsonlz4 in $new_profile"

    load_config
    local old_profile="$LOCAL_PROFILE"

    header "set-local-profile"
    set_config_local_profile "$new_profile"
    ok "Local profile updated"
    dim "  old: $old_profile"
    dim "  new: $new_profile"
    printf "\n"
}

# ─── Merge ────────────────────────────────────────────────────────────
cmd_merge() {
    load_config
    local restart=false
    for arg in "$@"; do
        [[ "$arg" == "--restart" ]] && restart=true
    done

    header "merge"

    if [[ "$MODE" == "ssh" ]]; then
        local remote="$REMOTE_USER@$REMOTE_HOST"
        printf "  ${D}local${R} ${PURPLE}⇄${R} ${WHITE}${B}%s${R}\n\n" "$REMOTE_HOST"
    elif [[ "$MODE" == "r2" ]]; then
        printf "  ${D}local${R} ${PURPLE}⇄${R} ${WHITE}${B}R2 cloud${R}\n\n"
    else
        printf "  ${D}local${R} ${PURPLE}⇄${R} ${WHITE}${B}Storage Box${R}\n\n"
    fi

    [[ "$restart" == "true" ]] && zen_close_local

    # Download remote files to temp dir
    local tmp_dir=$(mktemp -d)

    if [[ "$MODE" == "ssh" ]]; then
        local remote="$REMOTE_USER@$REMOTE_HOST"
        step "  ↓" "Fetching remote sessions..."
        scp -q "$remote:$REMOTE_PROFILE/zen-sessions.jsonlz4" "$tmp_dir/zen-sessions.jsonlz4" 2>/dev/null \
            || die "could not download remote zen-sessions"
        scp -q "$remote:$REMOTE_PROFILE/sessionstore-backups/recovery.jsonlz4" "$tmp_dir/recovery.jsonlz4" 2>/dev/null || true
    else
        local backend_py config_json label
        if [[ "$MODE" == "r2" ]]; then
            backend_py=$(find_py "cloud.py")
            config_json=$(cloud_config_json)
            label="R2"
        else
            backend_py=$(find_py "storagebox.py")
            config_json=$(storagebox_config_json)
            label="Storage Box"
        fi
        step "  ↓" "Downloading from $label..."
        "$PYTHON_BIN" "$backend_py" pull "$(echo "$config_json" | "$PYTHON_BIN" -c "import sys,json; d=json.load(sys.stdin); d['profile']='$tmp_dir'; print(json.dumps(d))")" >/dev/null \
            || die "could not download from $label"
        # Move recovery for merge.py
        [[ -f "$tmp_dir/sessionstore-backups/recovery.jsonlz4" ]] && \
            cp "$tmp_dir/sessionstore-backups/recovery.jsonlz4" "$tmp_dir/recovery.jsonlz4"
    fi
    ok "Remote files downloaded"

    # Run merge
    step "  ⇄" "Merging sessions..."
    local merge_py
    merge_py=$(find_py "merge.py")

    local result
    result=$("$PYTHON_BIN" "$merge_py" "$LOCAL_PROFILE" "$tmp_dir") || die "merge failed"

    local new_spaces new_tabs new_folders new_groups session_merged
    new_spaces=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['new_spaces'])")
    new_tabs=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['new_tabs'])")
    new_folders=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['new_folders'])")
    new_groups=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['new_groups'])")
    session_merged=$(echo "$result" | "$PYTHON_BIN" -c "import sys,json; print(json.load(sys.stdin)['session_merged'])")

    printf "\n"
    [[ "$new_spaces" -gt 0 ]] && ok "$new_spaces new spaces"
    [[ "$new_tabs" -gt 0 ]] && ok "$new_tabs new tabs"
    [[ "$new_folders" -gt 0 ]] && ok "$new_folders new folders"
    [[ "$new_groups" -gt 0 ]] && ok "$new_groups new groups"
    [[ "$session_merged" == "True" ]] && ok "Session store updated"

    if [[ "$new_spaces" -eq 0 && "$new_tabs" -eq 0 ]]; then
        dim "  Nothing new to merge"
    fi

    rm -rf "$tmp_dir"

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_local

    printf "\n  ${GREEN}${B}✓ Merge complete${R}\n\n"
}

# ─── Main ─────────────────────────────────────────────────────────────
case "${1:-help}" in
    push)   shift; cmd_push "$@" ;;
    pull)   shift; cmd_pull "$@" ;;
    merge)  shift; cmd_merge "$@" ;;
    sync)   shift; cmd_sync "$@" ;;
    set-local-profile) shift; cmd_set_local_profile "$@" ;;
    extract-key) shift; cmd_extract_key "$@" ;;
    status) cmd_status ;;
    init)   cmd_init ;;
    help|--help|-h) usage ;;
    *)      die "unknown command: $1. Run 'zen-sync help'" ;;
esac
