#!/bin/bash
set -euo pipefail

# ─── Config ───────────────────────────────────────────────────────────
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zen-sync"
CONFIG_FILE="$CONFIG_DIR/config"

# ─── Colors & UI ─────────────────────────────────────────────────────
R="\033[0m"
B="\033[1m"
D="\033[2m"
PURPLE="\033[38;2;147;130;220m"
GREEN="\033[38;2;130;200;160m"
RED="\033[38;2;210;100;120m"
YELLOW="\033[38;2;220;180;100m"
GRAY="\033[38;2;100;100;110m"
WHITE="\033[38;2;200;200;210m"

die()  { printf "${RED}${B} error${R} ${WHITE}%s${R}\n" "$*" >&2; exit 1; }
info() { printf "${PURPLE}${B}  %s${R}\n" "$*"; }
ok()   { printf "${GREEN}  ✓${R} ${WHITE}%s${R}\n" "$*"; }
fail() { printf "${RED}  ✗${R} ${WHITE}%s${R}\n" "$*" >&2; }
step() { printf "${PURPLE}%s${R} ${D}%s${R}\n" "$1" "$2"; }
dim()  { printf "${GRAY}%s${R}\n" "$*"; }

header() {
    local label="zen-sync $1"
    local inner=33
    local pad=$(( (inner - ${#label}) / 2 ))
    local rpad=$(( inner - ${#label} - pad ))
    printf "\n"
    printf "${PURPLE}${B}  ╭─────────────────────────────────╮${R}\n"
    printf "${PURPLE}${B}  │${R}${B}%*s%s%*s${PURPLE}${B}│${R}\n" "$((pad))" "" "$label" "$((rpad))" ""
    printf "${PURPLE}${B}  ╰─────────────────────────────────╯${R}\n"
    printf "\n"
}

usage() {
    header "help"
    printf "${B}  Usage:${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}push${R}              ${D}Push session to remote${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}pull${R}              ${D}Pull session from remote${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}pull --spaces-only${R} ${D}Pull only spaces/workspaces files${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}merge${R}             ${D}Merge remote tabs into local${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}sync${R}              ${D}Backup remote, merge latest, then push${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}set-local-profile${R} ${D}Change local profile used for sync${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}push --restart${R}    ${D}Close Zen, sync, reopen${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}extract-key${R}       ${D}Export age key file (R2/StorageBox key mode)${R}\n"
    printf "    ${WHITE}zen-sync${R} ${YELLOW}status${R}            ${D}Compare both devices${R}\n"
    printf "    ${WHITE}zen-sync${R} ${YELLOW}init${R}              ${D}Setup wizard${R}\n"
    printf "\n"
    printf "  ${D}Modes: ssh (device-to-device), r2 (Cloudflare R2), storagebox (WebDAV)${R}\n"
    printf "  ${D}Config: %s${R}\n" "$CONFIG_DIR/config"
    printf "\n"
    exit 0
}

detect_python() {
    if [[ -n "${ZEN_SYNC_PYTHON:-}" ]]; then
        if [[ -x "$ZEN_SYNC_PYTHON" ]]; then
            echo "$ZEN_SYNC_PYTHON"
            return 0
        fi
        if command -v "$ZEN_SYNC_PYTHON" >/dev/null 2>&1; then
            command -v "$ZEN_SYNC_PYTHON"
            return 0
        fi
        die "ZEN_SYNC_PYTHON is set but not executable/found: $ZEN_SYNC_PYTHON"
    fi

    # On macOS, prefer Homebrew Python because python.org framework builds may
    # have an uninitialized CA bundle and fail TLS verification.
    if [[ "$(uname -s)" == "Darwin" ]]; then
        if [[ -x "/opt/homebrew/bin/python3" ]]; then
            echo "/opt/homebrew/bin/python3"
            return 0
        fi
        if [[ -x "/usr/local/bin/python3" ]]; then
            echo "/usr/local/bin/python3"
            return 0
        fi
    fi

    if command -v python3 >/dev/null 2>&1; then
        echo "python3"
    elif command -v python >/dev/null 2>&1; then
        echo "python"
    else
        die "python not found in PATH"
    fi
}

resolve_tool_path() {
    local name="$1"
    if command -v "$name" >/dev/null 2>&1; then
        command -v "$name"
        return 0
    fi
    if command -v "${name}.exe" >/dev/null 2>&1; then
        command -v "${name}.exe"
        return 0
    fi
    if command -v cmd.exe >/dev/null 2>&1; then
        local win_path
        win_path=$(cmd.exe /c "where $name" 2>/dev/null | tr -d '\r' | head -n 1)
        if [[ -n "$win_path" ]]; then
            to_unix_path "$win_path"
            return 0
        fi
    fi
    return 1
}

resolve_age_keygen() {
    local age_bin="$1"
    local keygen_bin=""

    keygen_bin=$(resolve_tool_path "age-keygen" || true)
    if [[ -n "$keygen_bin" ]]; then
        echo "$keygen_bin"
        return 0
    fi

    # Try sibling binary next to age (common on Windows winget installs).
    local dir
    dir="$(dirname "$age_bin")"
    if [[ -f "$dir/age-keygen.exe" ]]; then
        echo "$dir/age-keygen.exe"
        return 0
    fi
    if [[ -f "$dir/age-keygen" ]]; then
        echo "$dir/age-keygen"
        return 0
    fi

    return 1
}

human_bytes() {
    local bytes="${1:-0}"
    local units=(B KiB MiB GiB TiB)
    local i=0
    local value="$bytes"

    while [[ "$value" -ge 1024 && "$i" -lt 4 ]]; do
        value=$((value / 1024))
        i=$((i + 1))
    done

    echo "${value}${units[$i]}"
}

# ─── Zen process management ──────────────────────────────────────────
zen_close_remote() {
    local remote="$1"
    if ssh "$remote" 'pgrep -f "zen-bin|zen-browser|Zen Browser|zen.exe" >/dev/null 2>&1'; then
        step "  ◼" "Closing Zen on remote..."
        ssh -o ConnectTimeout=5 "$remote" 'pkill -f "zen-bin|zen-browser|Zen Browser|zen.exe" 2>/dev/null || true; exit 0' || true
        sleep 5
    fi
}

zen_open_remote() {
    local remote="$1"
    step "  ▶" "Reopening Zen on remote..."
    ssh "$remote" '
        if command -v zen-browser >/dev/null 2>&1; then
            nohup zen-browser >/dev/null 2>&1 </dev/null &
        elif command -v open >/dev/null 2>&1; then
            open -a "Zen Browser" >/dev/null 2>&1 || open -a "Zen" >/dev/null 2>&1 || true
        elif command -v cmd.exe >/dev/null 2>&1; then
            cmd.exe /c start "" zen.exe >/dev/null 2>&1 || true
        fi
        exit 0
    ' || true
}

zen_close_local() {
    local pids
    pids=$(pgrep -f "zen-bin|zen-browser|Zen Browser|zen.exe" 2>/dev/null || true)
    if [[ -n "$pids" ]]; then
        step "  ◼" "Closing Zen locally..."
        kill -SIGTERM $(echo "$pids" | head -1) 2>/dev/null || true
        sleep 3
    fi
}

zen_open_local() {
    step "  ▶" "Reopening Zen locally..."
    if command -v zen-browser >/dev/null 2>&1; then
        nohup zen-browser >/dev/null 2>&1 &
    elif command -v open >/dev/null 2>&1; then
        open -a "Zen Browser" >/dev/null 2>&1 || open -a "Zen" >/dev/null 2>&1 || true
    elif command -v cmd.exe >/dev/null 2>&1; then
        cmd.exe /c start "" zen.exe >/dev/null 2>&1 || true
    fi
}

# ─── Resolve script directory ────────────────────────────────────────
resolve_script_dir() {
    local dir
    dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # Follow symlink if needed
    if [[ -L "${BASH_SOURCE[0]}" ]]; then
        dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    fi
    echo "$dir"
}

SCRIPT_DIR="$(resolve_script_dir)"
PYTHON_BIN="$(detect_python)"

path_to_unix_lookup() {
    local raw="$1"
    [[ -n "$raw" ]] || return 0

    if [[ "$raw" =~ ^([A-Za-z]):\\(.*)$ ]]; then
        local drive="${BASH_REMATCH[1],,}"
        local rest="${BASH_REMATCH[2]//\\//}"
        if [[ -d "/mnt/$drive" ]]; then
            printf '/mnt/%s/%s\n' "$drive" "$rest"
        else
            printf '/%s/%s\n' "$drive" "$rest"
        fi
        return 0
    fi

    echo "$raw"
}

find_py() {
    local name="$1"
    local path="$SCRIPT_DIR/$name"
    [[ -f "$path" ]] && { echo "$path"; return; }

    if [[ -n "${ZEN_SYNC_LIB_DIR:-}" ]]; then
        path="$(path_to_unix_lookup "$ZEN_SYNC_LIB_DIR")/$name"
        [[ -f "$path" ]] && { echo "$path"; return; }
    fi

    path="$HOME/.local/lib/zen-sync/$name"
    [[ -f "$path" ]] && { echo "$path"; return; }

    if command -v cmd.exe >/dev/null 2>&1; then
        local userprofile
        userprofile=$(cmd.exe /c "echo %USERPROFILE%" 2>/dev/null | tr -d '\r' | tail -n 1)
        if [[ -n "$userprofile" && "$userprofile" != *"%USERPROFILE%"* ]]; then
            path="$(path_to_unix_lookup "$userprofile")/.local/lib/zen-sync/$name"
            [[ -f "$path" ]] && { echo "$path"; return; }
        fi
    fi

    die "$name not found. Re-run install."
}

# ─── Config management ────────────────────────────────────────────────
load_config() {
    [[ -f "$CONFIG_FILE" ]] || die "not configured. Run 'zen-sync init' first."
    source "$CONFIG_FILE"
    : "${MODE:?}" "${LOCAL_PROFILE:?}"

    if [[ "$MODE" == "ssh" ]]; then
        : "${REMOTE_HOST:?}" "${REMOTE_USER:?}" "${REMOTE_PROFILE:?}"
    elif [[ "$MODE" == "r2" ]]; then
        : "${R2_ACCOUNT_ID:?}" "${R2_ACCESS_KEY:?}" "${R2_SECRET_KEY:?}" "${R2_BUCKET:?}"
        if [[ "${AGE_MODE:-keyfile}" == "keyfile" ]]; then
            : "${AGE_KEY_PATH:?}"
        fi
    elif [[ "$MODE" == "storagebox" ]]; then
        : "${STORAGEBOX_URL:?}" "${STORAGEBOX_USER:?}" "${STORAGEBOX_PASS:?}" "${STORAGEBOX_PATH:?}"
        if [[ "${AGE_MODE:-keyfile}" == "keyfile" ]]; then
            : "${AGE_KEY_PATH:?}"
        fi
    else
        die "unknown mode: $MODE"
    fi
}

cloud_config_json() {
    printf '{"account_id":"%s","access_key":"%s","secret_key":"%s","bucket":"%s","age_key_path":"%s","age_mode":"%s","config_dir":"%s","profile":"%s","age_bin":"%s","age_keygen_bin":"%s"}' \
        "$R2_ACCOUNT_ID" "$R2_ACCESS_KEY" "$R2_SECRET_KEY" "$R2_BUCKET" "${AGE_KEY_PATH:-}" "${AGE_MODE:-keyfile}" "$CONFIG_DIR" "$LOCAL_PROFILE" "${AGE_BIN:-age}" "${AGE_KEYGEN_BIN:-age-keygen}"
}

storagebox_config_json() {
    printf '{"url":"%s","username":"%s","password":"%s","path":"%s","age_key_path":"%s","age_mode":"%s","config_dir":"%s","profile":"%s","age_bin":"%s","age_keygen_bin":"%s"}' \
        "$STORAGEBOX_URL" "$STORAGEBOX_USER" "$STORAGEBOX_PASS" "$STORAGEBOX_PATH" "${AGE_KEY_PATH:-}" "${AGE_MODE:-keyfile}" "$CONFIG_DIR" "$LOCAL_PROFILE" "${AGE_BIN:-age}" "${AGE_KEYGEN_BIN:-age-keygen}"
}

to_unix_path() {
    local raw="$1"
    [[ -n "$raw" ]] || return 0

    if command -v cygpath >/dev/null 2>&1; then
        cygpath -u "$raw" 2>/dev/null && return 0
    fi

    # Fallback for Git Bash/WSL environments where APPDATA is a Windows path.
    local norm="${raw//\\//}"
    if [[ "$norm" =~ ^([A-Za-z]):(.*)$ ]]; then
        local drive="${BASH_REMATCH[1],,}"
        local rest="${BASH_REMATCH[2]}"
        if [[ -d "/mnt/$drive" ]]; then
            printf '/mnt/%s%s\n' "$drive" "$rest"
        else
            printf '/%s%s\n' "$drive" "$rest"
        fi
    else
        printf '%s\n' "$norm"
    fi
}

to_windows_path() {
    local raw="$1"
    [[ -n "$raw" ]] || return 0

    if command -v wslpath >/dev/null 2>&1; then
        wslpath -w "$raw" 2>/dev/null && return 0
    fi

    local norm="${raw//\\//}"
    if [[ "$norm" =~ ^/mnt/([A-Za-z])/(.*)$ ]]; then
        local drive="${BASH_REMATCH[1]^}"
        local rest="${BASH_REMATCH[2]//\//\\}"
        printf '%s:\\%s\n' "$drive" "$rest"
        return 0
    fi
    if [[ "$norm" =~ ^/([A-Za-z])/(.*)$ ]]; then
        local drive="${BASH_REMATCH[1]^}"
        local rest="${BASH_REMATCH[2]//\//\\}"
        printf '%s:\\%s\n' "$drive" "$rest"
        return 0
    fi

    printf '%s\n' "$raw"
}

generate_age_key() {
    local keygen_bin="$1"
    local age_key="$2"

    if [[ "$keygen_bin" == *.exe ]] && command -v cmd.exe >/dev/null 2>&1; then
        local age_key_win
        age_key_win=$(to_windows_path "$age_key")

        # First try direct execution from bash/WSL with a Windows-style output path.
        if "$keygen_bin" -o "$age_key_win"; then
            return 0
        fi

        # Fallback to cmd.exe invocation with cmd-friendly quoting.
        local keygen_win
        keygen_win=$(to_windows_path "$keygen_bin")
        cmd.exe /d /s /c "\"\"$keygen_win\" -o \"$age_key_win\"\"" || return 1
    else
        "$keygen_bin" -o "$age_key" || return 1
    fi
}

default_age_key_path() {
    local age_bin="$1"

    if [[ "$age_bin" == *.exe ]]; then
        local win_appdata
        win_appdata=$(windows_appdata_dir)
        if [[ -n "$win_appdata" ]]; then
            echo "$win_appdata/zen-sync/age-key.txt"
            return 0
        fi
    fi

    echo "$CONFIG_DIR/age-key.txt"
}

find_windows_profiles_via_cmd() {
    command -v cmd.exe >/dev/null 2>&1 || return 0

    local rows
    rows=$(cmd.exe /c "for /d %P in (\"%APPDATA%\\zen\\Profiles\\*\") do @if exist \"%P\\zen-sessions.jsonlz4\" echo %P" 2>/dev/null | tr -d '\r')
    [[ -n "$rows" ]] || return 0

    while IFS= read -r win_path; do
        [[ -n "$win_path" ]] || continue
        to_unix_path "$win_path"
    done <<< "$rows"
}

windows_appdata_dir() {
    local raw="${APPDATA:-}"
    if [[ -z "$raw" ]] && command -v cmd.exe >/dev/null 2>&1; then
        raw=$(cmd.exe /c "echo %APPDATA%" 2>/dev/null | tr -d '\r' | tail -n 1)
    fi

    # Skip unresolved placeholder values like %APPDATA%.
    if [[ -z "$raw" || "$raw" == *"%APPDATA%"* ]]; then
        return 0
    fi

    to_unix_path "$raw"
}

find_local_profile() {
    local win_appdata=""
    win_appdata=$(windows_appdata_dir)

    local candidates=(
        "$HOME/.zen"
        "$HOME/Library/Application Support/zen"
        "${APPDATA:-$HOME/AppData/Roaming}/zen"
        "$HOME/AppData/Roaming/zen"
        "$win_appdata/zen"
        "$win_appdata/zen/Profiles"
    )
    local profiles=()
    local seen=""

    add_profile() {
        local p="$1"
        [[ -n "$p" ]] || return 0
        if [[ -n "$seen" ]] && printf '%s' "$seen" | grep -Fqx -- "$p"; then
            return 0
        fi
        profiles+=("$p")
        seen+="$p"$'\n'
    }

    # On Windows hosts, query cmd directly for authoritative profile paths.
    while IFS= read -r d; do
        [[ -n "$d" && -f "$d/zen-sessions.jsonlz4" ]] && add_profile "$d"
    done < <(find_windows_profiles_via_cmd)

    local base
    for base in "${candidates[@]}"; do
        [[ -d "$base" ]] || continue

        while IFS= read -r d; do
            [[ -f "$d/zen-sessions.jsonlz4" ]] && add_profile "$d"
        done < <(find "$base" -maxdepth 3 -type d \( -name "*.Default (release)" -o -name "*.default-release" \) 2>/dev/null)

        while IFS= read -r d; do
            [[ -f "$d/zen-sessions.jsonlz4" ]] && add_profile "$d"
        done < <(find "$base" -maxdepth 3 -type d 2>/dev/null)
    done

    if [[ ${#profiles[@]} -gt 0 ]]; then
        local unique_profiles=()
        local p
        while IFS= read -r p; do
            [[ -n "$p" ]] && unique_profiles+=("$p")
        done < <(printf '%s\n' "${profiles[@]}" | awk 'NF && !seen[$0]++')
        profiles=("${unique_profiles[@]}")
    fi

    [[ ${#profiles[@]} -gt 0 ]] || die "no Zen profile found with zen-sessions.jsonlz4 (checked Linux/macOS/Windows paths, including %APPDATA%/zen/Profiles)"

    if [[ ${#profiles[@]} -eq 1 ]]; then
        echo "${profiles[0]}"
    else
        echo "Multiple profiles found:" >&2
        for i in "${!profiles[@]}"; do
            echo "  [$i] ${profiles[$i]}" >&2
        done
        read -rp "Select profile [0]: " choice
        echo "${profiles[${choice:-0}]}"
    fi
}

# ─── Init ─────────────────────────────────────────────────────────────
prompt() {
    local label="$1" default="${2:-}"
    if [[ -n "$default" ]]; then
        printf "  ${PURPLE}›${R} ${WHITE}%s${R} ${D}[%s]${R} " "$label" "$default"
    else
        printf "  ${PURPLE}›${R} ${WHITE}%s${R} " "$label"
    fi
}

secret_prompt() {
    local label="$1"
    local val=""
    printf "  ${PURPLE}›${R} ${WHITE}%s${R} ${D}(hidden)${R} " "$label" >&2

    if [[ -r /dev/tty ]]; then
        IFS= read -r -s val < /dev/tty
    else
        IFS= read -r -s val
    fi

    printf "\n" >&2
    echo "$val"
}

cmd_init() {
    mkdir -p "$CONFIG_DIR"
    header "init"

    printf "  ${WHITE}Choose sync mode:${R}\n\n"
    printf "    ${PURPLE}❯${R} ${GREEN}1${R}  ${B}SSH${R}   ${D}Direct device-to-device (same network)${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}2${R}  ${B}R2${R}    ${D}Cloudflare R2 cloud (works anywhere)${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}3${R}  ${B}Storage Box${R} ${D}WebDAV (Hetzner-style remote storage)${R}\n"
    printf "\n"
    prompt "Mode" "1"
    read -r mode_choice
    local mode="ssh"
    [[ "$mode_choice" == "2" ]] && mode="r2"
    [[ "$mode_choice" == "3" ]] && mode="storagebox"

    printf "\n"

    # Find local profile
    step "  ⟳" "Finding local profile..."
    local local_profile
    local_profile=$(find_local_profile)
    ok "Local: $(basename "$local_profile")"

    printf "\n"

    if [[ "$mode" == "ssh" ]]; then
        init_ssh "$local_profile"
    elif [[ "$mode" == "r2" ]]; then
        init_r2 "$local_profile"
    else
        init_storagebox "$local_profile"
    fi
}

init_ssh() {
    local local_profile="$1"

    prompt "Remote host (IP or hostname)"; read -r host
    prompt "Remote user" "$USER"; read -r user
    user="${user:-$USER}"

    printf "\n"
    step "  ⟳" "Testing SSH..."
    ssh -o ConnectTimeout=5 "$user@$host" "echo ok" >/dev/null 2>&1 \
        || die "cannot connect to $user@$host"
    ok "SSH connected"

    step "  ⟳" "Finding remote profile..."
    local remote_profile
    remote_profile=$(ssh "$user@$host" '
        for base in "$HOME/.zen" "$HOME/Library/Application Support/zen" "$APPDATA/zen" "$HOME/AppData/Roaming/zen"; do
            [ -d "$base" ] || continue
            found=$(find "$base" -maxdepth 3 -type f -name "zen-sessions.jsonlz4" 2>/dev/null | head -1)
            if [ -n "$found" ]; then
                dirname "$found"
                exit 0
            fi
        done
        exit 1
    ')
    [[ -n "$remote_profile" ]] || die "no Zen profile found on remote"
    ok "Remote: $(basename "$remote_profile")"

    cat > "$CONFIG_FILE" <<CONF
MODE="ssh"
REMOTE_HOST="$host"
REMOTE_USER="$user"
LOCAL_PROFILE="$local_profile"
REMOTE_PROFILE="$remote_profile"
CONF

    printf "\n"
    printf "  ${GREEN}${B}✓ Config saved${R} ${D}(SSH mode)${R}\n"
    dim "  Use 'zen-sync push' or 'zen-sync pull' to start syncing"
    printf "\n"
}

init_r2() {
    local local_profile="$1"

    local age_bin
    age_bin=$(resolve_tool_path "age") || die "age not installed in this shell. Install age and ensure bash can find it."
    local age_keygen_bin
    age_keygen_bin=$(resolve_age_keygen "$age_bin") || die "age-keygen not found. Install full age package (includes age-keygen)."

    prompt "Cloudflare Account ID"; read -r account_id
    prompt "R2 Access Key ID"; read -r access_key
    prompt "R2 Secret Access Key"; read -r secret_key
    prompt "R2 Bucket name"; read -r bucket

    # Test connection
    printf "\n"
    step "  ⟳" "Testing R2 connection..."
    local cloud_py
    cloud_py=$(find_py "cloud.py")
    local test_config
    test_config=$(printf '{"account_id":"%s","access_key":"%s","secret_key":"%s","bucket":"%s"}' \
        "$account_id" "$access_key" "$secret_key" "$bucket")
    if "$PYTHON_BIN" "$cloud_py" test "$test_config" >/dev/null 2>&1; then
        ok "R2 connected"
    else
        die "could not connect to R2. Check your credentials and bucket name."
    fi

    # Encryption setup
    printf "\n"
    printf "  ${WHITE}Encryption method:${R}\n\n"
    printf "    ${PURPLE}❯${R} ${GREEN}1${R}  ${B}Passphrase${R}   ${D}Same passphrase on all devices (recommended)${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}2${R}  ${B}Key file${R}     ${D}Generate key, copy to other devices${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}3${R}  ${B}Import key${R}   ${D}Use an existing age key file${R}\n"
    printf "\n"
    prompt "Encryption" "1"; read -r enc_choice
    local enc_mode="passphrase"
    local import_existing_key="false"
    [[ "$enc_choice" == "2" ]] && enc_mode="keyfile"
    if [[ "$enc_choice" == "3" ]]; then
        enc_mode="keyfile"
        import_existing_key="true"
    fi

    if [[ "$enc_mode" == "passphrase" && "$age_bin" == *.exe ]]; then
        dim "  Passphrase mode is unreliable with Windows age.exe in this shell."
        dim "  Switching to key file mode to avoid hangs."
        enc_mode="keyfile"
    fi

    local age_key
    age_key=$(default_age_key_path "$age_bin")
    printf "\n"

    if [[ "$enc_mode" == "passphrase" ]]; then
        local passphrase
        printf "  ${PURPLE}›${R} ${WHITE}Passphrase${R} ${D}(hidden, use the same on all devices)${R} "
        read -rs passphrase
        printf "\n"
        echo "$passphrase" > "$CONFIG_DIR/passphrase"
        chmod 600 "$CONFIG_DIR/passphrase"
        ok "Passphrase saved"
        dim "  Use the same passphrase when setting up other devices"

        cat > "$CONFIG_FILE" <<CONF
MODE="r2"
R2_ACCOUNT_ID="$account_id"
R2_ACCESS_KEY="$access_key"
R2_SECRET_KEY="$secret_key"
R2_BUCKET="$bucket"
AGE_MODE="passphrase"
    AGE_BIN="$age_bin"
