    else
        if [[ "$import_existing_key" == "true" ]]; then
            local source_key
            prompt "Path to existing age key file"; read -r source_key
            source_key="${source_key/#\~/$HOME}"
            [[ -n "$source_key" ]] || die "key file path cannot be empty"
            [[ -f "$source_key" ]] || die "age key file not found: $source_key"

            mkdir -p "$(dirname "$age_key")"
            if [[ "$source_key" != "$age_key" ]]; then
                cp "$source_key" "$age_key" || die "failed to copy age key from $source_key"
            fi
            chmod 600 "$age_key"
            ok "Imported age key to $age_key"
        elif [[ -f "$age_key" ]]; then
            ok "Using existing age key"
        else
            step "  🔑" "Generating age encryption key..."
            mkdir -p "$(dirname "$age_key")"
            generate_age_key "$age_keygen_bin" "$age_key" || die "failed to generate age key using $age_keygen_bin"
            chmod 600 "$age_key"
            ok "Key saved to $age_key"
        fi

        cat > "$CONFIG_FILE" <<CONF
MODE="storagebox"
STORAGEBOX_URL="$storage_url"
STORAGEBOX_USER="$storage_user"
STORAGEBOX_PASS="$storage_pass"
STORAGEBOX_PATH="$storage_path"
AGE_MODE="keyfile"
AGE_KEY_PATH="$age_key"
AGE_BIN="$age_bin"
AGE_KEYGEN_BIN="$age_keygen_bin"
LOCAL_PROFILE="$local_profile"
CONF
    fi
    chmod 600 "$CONFIG_FILE"

    printf "\n"
    printf "  ${GREEN}${B}✓ Config saved${R} ${D}(Storage Box mode)${R}\n"
    dim "  Use 'zen-sync push' or 'zen-sync pull' to start syncing"
    printf "\n"
}

